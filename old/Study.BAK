import { ListTodo, Play, CheckCircle, ChevronRight, Trophy, BookOpen, Calendar, ArrowLeft, ThumbsUp, AlertCircle, CalendarClock, PlusCircle, Trash2, Clock, AlertTriangle, Flame, Upload, ArrowUp, ArrowDown, ChevronLeft, ExternalLink, ClipboardPaste } from 'lucide-react';
import React, { useState, useEffect } from 'react';

// --- SVGの木のコンポーネント ---
const TreeGraphic = ({ progress, isDead }) => {
  const leafScale = 0.2 + (progress * 0.8);
  const leafColor = isDead ? "#8B4513" : "#4ade80";
  const trunkColor = "#78350f";

  return (
    <svg viewBox="0 0 200 200" className="w-48 h-48 drop-shadow-lg transition-transform duration-1000">
      <path d="M90 200 Q100 150 100 100 Q100 150 110 200 Z" fill={trunkColor} />
      <g style={{ transform: `scale(${isDead ? 0.8 : leafScale})`, transformOrigin: '100px 100px', transition: 'all 1s ease-out' }}>
        <circle cx="100" cy="70" r="50" fill={leafColor} opacity={isDead ? 0.8 : 1} />
        <circle cx="60" cy="90" r="35" fill={leafColor} opacity={isDead ? 0.8 : 1} />
        <circle cx="140" cy="90" r="35" fill={leafColor} opacity={isDead ? 0.8 : 1} />
        <circle cx="80" cy="40" r="30" fill={leafColor} opacity={isDead ? 0.8 : 1} />
        <circle cx="120" cy="40" r="30" fill={leafColor} opacity={isDead ? 0.8 : 1} />
      </g>
      {isDead && (
        <g>
          <path d="M 60 190 Q 65 185 70 195 Z" fill={leafColor} />
          <path d="M 130 195 Q 135 190 140 198 Z" fill={leafColor} />
          <path d="M 85 180 Q 90 175 95 185 Z" fill={leafColor} />
        </g>
      )}
    </svg>
  );
};

export default function App() {
  // 今日の日付文字列 (YYYY-MM-DD) を取得
  const getTodayStr = () => new Date().toISOString().split('T')[0];
  const todayStr = getTodayStr();

  // --- 状態管理 ---
  const [currentScreen, setCurrentScreen] = useState('setup');
  const [selectedDate, setSelectedDate] = useState(todayStr); // 表示中の日付を追加
  
  // 基本設定（AIのJSONデータで初期化）
  const [goal, setGoal] = useState('青山学院大学 文学部 合格');
  const [examDate, setExamDate] = useState('2027-02-15');
  const [dailyGoalTime, setDailyGoalTime] = useState(180); 
  
  // タスクリスト（AIが生成した青学プラン）
  const [tasks, setTasks] = useState([
    { id: 't1', subject: '英語', name: '中学3年間の英語を10時間で復習する本（基礎固め）', dailyTime: 60, startDate: '2026-03-26', deadline: '2026-04-10', completedDates: [], rescheduleDate: null },
    { id: 't2', subject: '国語', name: 'システム中学国語 漢字・語彙 基礎編（毎日少しずつ）', dailyTime: 30, startDate: '2026-03-26', deadline: '2026-04-30', completedDates: [], rescheduleDate: null },
    { id: 't3', subject: '日本史/世界史', name: '一度読んだら忘れない日本史（世界史）の教科書 導入', dailyTime: 90, startDate: '2026-03-26', deadline: '2026-05-31', completedDates: [], rescheduleDate: null },
    { id: 't4', subject: '英語', name: 'システム英単語 Basic 1〜800 徹底暗記', dailyTime: 60, startDate: '2026-04-11', deadline: '2026-05-31', completedDates: [], rescheduleDate: null },
    { id: 't5', subject: '国語', name: '田村のやさしく語る現代文（読み方の基本）', dailyTime: 30, startDate: '2026-05-01', deadline: '2026-06-15', completedDates: [], rescheduleDate: null },
    { id: 't6', subject: '英語', name: '大岩のいちばんはじめの英文法 超基礎文法編', dailyTime: 60, startDate: '2026-06-01', deadline: '2026-07-31', completedDates: [], rescheduleDate: null },
    { id: 't7', subject: '日本史/世界史', name: '時代と流れで覚える 歴史用語ターゲット（基礎用語）', dailyTime: 90, startDate: '2026-06-01', deadline: '2026-08-31', completedDates: [], rescheduleDate: null },
    { id: 't8', subject: '国語', name: '富井の古典文法をはじめからていねいに', dailyTime: 30, startDate: '2026-06-16', deadline: '2026-08-31', completedDates: [], rescheduleDate: null },
    { id: 't9', subject: '英語', name: 'システム英単語 Basic 801〜1550 徹底暗記', dailyTime: 45, startDate: '2026-08-01', deadline: '2026-09-30', completedDates: [], rescheduleDate: null },
    { id: 't10', subject: '英語', name: '高校英文法 基礎パターンドリル（反復練習）', dailyTime: 45, startDate: '2026-08-01', deadline: '2026-09-30', completedDates: [], rescheduleDate: null },
    { id: 't11', subject: '日本史/世界史', name: '金谷の日本史（または世界史）「なぜ」と「流れ」がわかる本', dailyTime: 90, startDate: '2026-09-01', deadline: '2026-11-30', completedDates: [], rescheduleDate: null },
    { id: 't12', subject: '英語', name: '入門英文問題精講 1〜72番（精読・構文解釈）', dailyTime: 60, startDate: '2026-10-01', deadline: '2026-12-31', completedDates: [], rescheduleDate: null },
    { id: 't13', subject: '国語', name: '読んで見て覚える重要古文単語315（単語暗記）', dailyTime: 30, startDate: '2026-09-01', deadline: '2026-11-30', completedDates: [], rescheduleDate: null }
  ]);

  // 新規タスク入力用フォーム状態
  const [formSubject, setFormSubject] = useState('');
  const [formTaskName, setFormTaskName] = useState('');
  const [formDailyTime, setFormDailyTime] = useState(30);
  const [formStartDate, setFormStartDate] = useState(todayStr);
  const [formDeadline, setFormDeadline] = useState('');
  const [jsonInput, setJsonInput] = useState(''); // ペースト用の状態を追加
  
  // タイマー関連
  const [activeTask, setActiveTask] = useState(null);
  const [timeLeft, setTimeLeft] = useState(0);
  const [timerTotal, setTimerTotal] = useState(0);
  const [isDead, setIsDead] = useState(false);
  
  // 振り返りデータ
  const [taskResult, setTaskResult] = useState(null); 
  const [reviewNote, setReviewNote] = useState('');
  const [rescheduleDate, setRescheduleDate] = useState('');

  // --- アクション ---
  const handleAddTask = () => {
    if (!formSubject || !formTaskName || !formStartDate || !formDeadline) {
      alert("科目、タスク名、開始日、期限は必須です");
      return;
    }
    if (formStartDate > formDeadline) {
      alert("開始日は期限より前の日付にしてください");
      return;
    }
    const newTask = {
      id: Date.now().toString(),
      subject: formSubject,
      name: formTaskName,
      dailyTime: Number(formDailyTime),
      startDate: formStartDate,
      deadline: formDeadline,
      completedDates: [],
      rescheduleDate: null
    };
    setTasks([...tasks, newTask]);
    setFormTaskName('');
    setFormDailyTime(30);
  };

  const handleRemoveTask = (id) => {
    setTasks(tasks.filter(t => t.id !== id));
  };

  const processImportedJson = (json) => {
    let importedTasks = [];
    if (json.tasks && Array.isArray(json.tasks)) {
      if (json.goal) setGoal(json.goal);
      if (json.examDate) setExamDate(json.examDate);
      if (json.dailyGoalTime) setDailyGoalTime(Number(json.dailyGoalTime));
      importedTasks = json.tasks;
    } else if (Array.isArray(json)) {
      importedTasks = json;
    } else {
      throw new Error("フォーマットが正しくありません。");
    }
    
    const formattedTasks = importedTasks.map((task, index) => ({
      id: `imported-${Date.now()}-${index}`,
      subject: task.subject || '未分類',
      name: task.name || '名称未設定',
      dailyTime: Number(task.dailyTime) || 30,
      startDate: task.startDate || todayStr,
      deadline: task.deadline || (json.examDate ? json.examDate : examDate),
      completedDates: [],
      rescheduleDate: null
    }));
    
    setTasks(formattedTasks);
    alert(`プランの取り込みが完了しました！\n目標や試験日、${formattedTasks.length}件のタスクを設定しました。`);
  };

  const handleFileUpload = (event) => {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const json = JSON.parse(e.target.result);
        processImportedJson(json);
      } catch (error) {
        alert("ファイルの読み込みに失敗しました。\n" + error.message);
      }
    };
    reader.readAsText(file);
    event.target.value = null;
  };

  const handlePasteJson = () => {
    if (!jsonInput.trim()) {
      alert("JSONデータをペーストしてください。");
      return;
    }
    try {
      const json = JSON.parse(jsonInput);
      processImportedJson(json);
      setJsonInput(''); // 成功したらクリア
    } catch (error) {
      alert("JSONの読み込みに失敗しました。コピーしたデータが正しいか確認してください。\n" + error.message);
    }
  };

  const handleFinishSetup = () => {
    if (tasks.length === 0) {
      alert("タスクを1つ以上登録してください");
      return;
    }
    setCurrentScreen('dashboard');
  };

  // --- 並び替えアクション ---
  const moveTask = (index, direction) => {
    const newTasks = [...tasks];
    const targetId = getTasksForDate(selectedDate)[index].id;
    const taskIndexInAll = tasks.findIndex(t => t.id === targetId);
    
    const swapTargetId = getTasksForDate(selectedDate)[index + direction]?.id;
    if (!swapTargetId) return;
    
    const swapIndexInAll = tasks.findIndex(t => t.id === swapTargetId);

    [newTasks[taskIndexInAll], newTasks[swapIndexInAll]] = [newTasks[swapIndexInAll], newTasks[taskIndexInAll]];
    setTasks(newTasks);
  };

  // --- タイマーとレビューアクション ---
  const handleStartTask = (task) => {
    setActiveTask(task);
    // デモ用: 10秒
    const totalSeconds = 10; 
    setTimeLeft(totalSeconds);
    setTimerTotal(totalSeconds);
    setIsDead(false);
    setCurrentScreen('timer');
  };

  const handleGiveUp = () => {
    setIsDead(true);
    setTimeout(() => {
      setCurrentScreen('dashboard');
      setActiveTask(null);
    }, 2000);
  };

  const handleFinishTimer = () => {
    setTaskResult(null); 
    setReviewNote('');
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    setRescheduleDate(tomorrow.toISOString().split('T')[0]);
    setCurrentScreen('review');
  };

  const handleSaveReview = () => {
    if (!taskResult) {
      alert("結果を選択してください。");
      return;
    }

    setTasks(tasks.map(t => {
      if (t.id === activeTask.id) {
        const newCompletedDates = [...t.completedDates];
        // 完了として記録する日付を selectedDate に変更
        if (taskResult === 'success' && !newCompletedDates.includes(selectedDate)) {
          newCompletedDates.push(selectedDate);
        }
        return { 
          ...t, 
          completedDates: newCompletedDates,
          rescheduleDate: taskResult === 'fail' ? rescheduleDate : null
        };
      }
      return t;
    }));
    
    setReviewNote('');
    setActiveTask(null);
    setCurrentScreen('dashboard');
  };

  useEffect(() => {
    let timerId;
    if (currentScreen === 'timer' && !isDead && timeLeft > 0) {
      timerId = setInterval(() => {
        setTimeLeft(prev => prev - 1);
      }, 1000);
    } else if (currentScreen === 'timer' && !isDead && timeLeft === 0) {
      handleFinishTimer();
    }
    return () => clearInterval(timerId);
  }, [currentScreen, timeLeft, isDead]);

  // --- データの取得ヘルパー ---
  const getTasksForDate = (dateStr) => {
    return tasks.filter(t => t.startDate <= dateStr && dateStr <= t.deadline);
  };

  const changeDate = (offset) => {
    const d = new Date(selectedDate);
    d.setDate(d.getDate() + offset);
    setSelectedDate(d.toISOString().split('T')[0]);
  };

  // --- 画面レンダリング ---
  const renderSetup = () => (
    <div className="flex flex-col h-full bg-slate-50 overflow-y-auto pb-8">
      <div className="bg-slate-800 text-white p-6 pt-10 pb-6 shadow-md shrink-0">
        <h1 className="text-xl font-bold mb-2 flex items-center gap-2">
          <BookOpen size={20} className="text-emerald-400" />
          マスタープラン作成
        </h1>
        <p className="text-sm text-slate-300">いつから・いつまで・毎日何分やるかを設定</p>
      </div>

      <div className="p-5 space-y-6">
        <div className="bg-white p-4 rounded-2xl shadow-sm border border-slate-200 space-y-3">
          <label className="block text-sm font-bold text-slate-700 flex items-center gap-2">
            <Trophy size={16} className="text-emerald-600"/>目標
          </label>
          <input 
            type="text" value={goal} onChange={(e) => setGoal(e.target.value)}
            className="w-full p-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:ring-2 focus:ring-emerald-500"
          />
          <div className="grid grid-cols-2 gap-3 mt-2">
            <div>
              <label className="block text-xs font-bold text-slate-700 flex items-center gap-1 mb-1">
                <Calendar size={14} className="text-emerald-600"/>試験日
              </label>
              <input 
                type="date" value={examDate} onChange={(e) => setExamDate(e.target.value)}
                className="w-full p-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:ring-2 focus:ring-emerald-500"
              />
            </div>
            <div>
              <label className="block text-xs font-bold text-slate-700 flex items-center gap-1 mb-1">
                <Clock size={14} className="text-emerald-600"/>1日の目標学習(分)
              </label>
              <input 
                type="number" step="30" value={dailyGoalTime} onChange={(e) => setDailyGoalTime(Number(e.target.value))}
                className="w-full p-2.5 rounded-xl border border-slate-200 bg-slate-50 text-sm focus:ring-2 focus:ring-emerald-500"
              />
            </div>
          </div>
        </div>

        <div className="bg-emerald-50 p-4 rounded-2xl border border-emerald-100 space-y-3">
          <h3 className="font-bold text-emerald-800 text-sm flex items-center gap-2">
            <PlusCircle size={16} />新規タスクを追加
          </h3>
          <div className="grid grid-cols-2 gap-2">
            <div>
              <label className="text-xs font-bold text-slate-600 mb-1 block">科目</label>
              <input type="text" placeholder="例: 英語" value={formSubject} onChange={e => setFormSubject(e.target.value)} className="w-full p-2 text-sm rounded-lg border border-slate-200" />
            </div>
            <div>
              <label className="text-xs font-bold text-slate-600 mb-1 block flex items-center gap-1"><Clock size={12}/>毎日の目安(分)</label>
              <input type="number" min="5" step="5" value={formDailyTime} onChange={e => setFormDailyTime(e.target.value)} className="w-full p-2 text-sm rounded-lg border border-slate-200" />
            </div>
          </div>
          <div>
            <label className="text-xs font-bold text-slate-600 mb-1 block">タスク名</label>
            <input type="text" placeholder="例: 鉄壁 1セクション" value={formTaskName} onChange={e => setFormTaskName(e.target.value)} className="w-full p-2 text-sm rounded-lg border border-slate-200" />
          </div>
          <div className="grid grid-cols-2 gap-2">
            <div>
              <label className="text-xs font-bold text-slate-600 mb-1 block">いつから？</label>
              <input type="date" value={formStartDate} onChange={e => setFormStartDate(e.target.value)} className="w-full p-2 text-sm rounded-lg border border-slate-200" />
            </div>
            <div>
              <label className="text-xs font-bold text-slate-600 mb-1 block">いつまで？</label>
              <input type="date" value={formDeadline} onChange={e => setFormDeadline(e.target.value)} className="w-full p-2 text-sm rounded-lg border border-slate-200" />
            </div>
          </div>
          <button onClick={handleAddTask} className="w-full py-2.5 mt-2 bg-emerald-600 text-white font-bold rounded-lg shadow hover:bg-emerald-700 transition">
            リストに追加
          </button>
        </div>

        <div className="bg-slate-100 p-4 rounded-2xl border border-slate-200 space-y-3">
          <div className="flex items-center justify-between">
            <h3 className="font-bold text-slate-700 text-sm flex items-center gap-2">
              <Upload size={16} />AIプランを取り込む
            </h3>
            <a href="https://gemini.google.com/gem/af25bc8ac115" target="_blank" rel="noopener noreferrer" className="text-emerald-600 text-xs font-bold hover:underline flex items-center gap-1">
              専用AIを開く <ExternalLink size={12} />
            </a>
          </div>
          <p className="text-xs text-slate-500">AIが出力したテキストをペーストするか、ファイルをアップロードしてください。</p>
          
          <textarea 
            value={jsonInput}
            onChange={(e) => setJsonInput(e.target.value)}
            placeholder="ここにAIの出力をペースト..."
            className="w-full p-3 rounded-xl border border-slate-300 text-xs font-mono h-24 focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 bg-white"
          />
          <button 
            onClick={handlePasteJson}
            className="w-full py-2.5 bg-slate-800 text-white font-bold rounded-lg shadow text-sm hover:bg-slate-700 transition flex items-center justify-center gap-2"
          >
            <ClipboardPaste size={16} />
            ペーストしたデータを取り込む
          </button>

          <div className="relative flex py-2 items-center">
            <div className="flex-grow border-t border-slate-300"></div>
            <span className="flex-shrink-0 mx-4 text-slate-400 text-xs font-bold">またはファイルで</span>
            <div className="flex-grow border-t border-slate-300"></div>
          </div>

          <input 
            type="file" accept=".json" onChange={handleFileUpload}
            className="w-full text-sm text-slate-500 file:mr-4 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-slate-200 file:text-slate-700 hover:file:bg-slate-300 cursor-pointer"
          />
        </div>

        <div className="space-y-3">
          <h3 className="font-bold text-slate-700 text-sm">登録済みタスク ({tasks.length}件)</h3>
          {tasks.map(t => (
            <div key={t.id} className="bg-white p-3 rounded-xl border border-slate-200 flex items-start justify-between shadow-sm">
              <div className="flex-1 pr-2">
                <span className="text-[10px] font-bold bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full">{t.subject}</span>
                <p className="font-bold text-slate-800 mt-1 text-sm">{t.name}</p>
                <p className="text-[10px] text-slate-500 mt-1">
                  期間: {t.startDate.slice(5).replace('-','/')} 〜 {t.deadline.slice(5).replace('-','/')} | 毎日: {t.dailyTime}分
                </p>
              </div>
              <button onClick={() => handleRemoveTask(t.id)} className="p-2 text-slate-400 hover:text-red-500"><Trash2 size={16}/></button>
            </div>
          ))}
        </div>
        
        <button onClick={handleFinishSetup} className="w-full py-4 bg-slate-800 hover:bg-slate-900 text-white rounded-2xl font-bold text-lg shadow-lg flex items-center justify-center gap-2 mt-8">
          このスケジュールで開始
        </button>
      </div>
    </div>
  );

  const renderDashboard = () => {
    const displayTasks = getTasksForDate(selectedDate);
    
    // 表示日の合計タスク時間
    const displayTotalTime = displayTasks.reduce((acc, t) => acc + t.dailyTime, 0);
    // 表示日の完了済みタスク時間
    const displayCompletedTime = displayTasks
      .filter(t => t.completedDates.includes(selectedDate))
      .reduce((acc, t) => acc + t.dailyTime, 0);
    
    // 目標に対する進捗 (%)
    const progressPercent = dailyGoalTime === 0 ? 0 : Math.min(100, Math.round((displayCompletedTime / dailyGoalTime) * 100));

    return (
      <div className="flex flex-col h-full bg-slate-50">
        <div className="bg-emerald-600 text-white p-6 pt-10 pb-6 rounded-b-3xl shadow-md shrink-0">
          {/* 日付ナビゲーション */}
          <div className="flex items-center justify-between mb-4 bg-emerald-700/50 rounded-full p-1">
            <button onClick={() => changeDate(-1)} className="p-2 hover:bg-emerald-600 rounded-full transition-colors"><ChevronLeft size={16} /></button>
            <span className="font-bold text-sm tracking-widest flex items-center gap-2">
              <Calendar size={14} />
              {selectedDate === todayStr ? 'TODAY' : selectedDate.slice(5).replace('-','/')}
            </span>
            <button onClick={() => changeDate(1)} className="p-2 hover:bg-emerald-600 rounded-full transition-colors"><ChevronRight size={16} /></button>
          </div>

          <div className="flex justify-between items-start mb-4">
            <div>
              <p className="text-emerald-100 text-[10px] font-medium mb-1 uppercase tracking-wider">Goal Progress</p>
              <h2 className="text-lg font-bold leading-tight flex items-end gap-1">
                {Math.floor(displayCompletedTime / 60)}h {displayCompletedTime % 60}m 
                <span className="text-sm font-normal text-emerald-200">/ {Math.floor(dailyGoalTime / 60)}h {dailyGoalTime % 60}m</span>
              </h2>
            </div>
          </div>
          
          <div className="mt-2">
            <div className="flex justify-between text-xs mb-1.5 font-bold">
              <span>{selectedDate === todayStr ? '本日' : 'この日'}の進捗</span>
              <span>{progressPercent}%</span>
            </div>
            <div className="h-2.5 bg-emerald-800/50 rounded-full overflow-hidden">
              <div className="h-full bg-white rounded-full transition-all duration-500" style={{ width: `${progressPercent}%` }} />
            </div>
            <p className="text-[10px] text-emerald-200 mt-2 text-right">割り当て済みタスク: 計 {displayTotalTime} 分</p>
          </div>
          
          <div className="flex gap-2 mt-4">
            <button onClick={() => setCurrentScreen('schedule')} className="flex-1 py-2.5 bg-emerald-800 hover:bg-emerald-900 rounded-xl text-sm font-bold flex items-center justify-center gap-2 shadow-inner">
              <Calendar size={16} className="text-emerald-400" />
              学習ロードマップ
            </button>
          </div>
        </div>

        <div className="flex-1 overflow-y-auto p-5 space-y-4">
          <div className="flex justify-between items-end mb-2">
            <h3 className="font-bold text-slate-800 flex items-center gap-2">
              <ListTodo size={20} className="text-emerald-600"/>
              {selectedDate === todayStr ? '本日' : 'この日'}のやることリスト
            </h3>
            <button onClick={() => {setCurrentScreen('setup'); setSelectedDate(todayStr);}} className="text-xs text-emerald-600 font-bold underline">プラン編集</button>
          </div>
          
          {displayTasks.length === 0 ? (
            <div className="text-center p-8 bg-white rounded-2xl border border-slate-200">
              <Trophy size={40} className="mx-auto text-emerald-300 mb-2" />
              <p className="font-bold text-slate-600">この日のタスクはありません！</p>
              <p className="text-xs text-slate-400 mt-2">※期間外のタスクは表示されません。</p>
            </div>
          ) : (
            <div className="space-y-3">
              {displayTasks.map((task, index) => {
                const isDateCompleted = task.completedDates.includes(selectedDate);
                const daysLeft = Math.ceil((new Date(task.deadline) - new Date()) / (1000 * 60 * 60 * 24));
                const isWarning = daysLeft <= 14; 

                return (
                  <div key={task.id} className={`bg-white rounded-2xl shadow-sm border ${isDateCompleted ? 'border-emerald-200 bg-emerald-50/50' : 'border-slate-200'} p-3 flex items-center gap-3 transition-colors`}>
                    
                    {/* 完了ステータスアイコン */}
                    <div className="shrink-0">
                      {isDateCompleted ? (
                        <CheckCircle size={24} className="text-emerald-500" />
                      ) : (
                        <div className="w-6 h-6 rounded-full border-2 border-slate-300" />
                      )}
                    </div>

                    {/* タスク情報 */}
                    <div className={`flex-1 min-w-0 ${isDateCompleted ? 'opacity-50' : ''}`}>
                      <div className="flex items-center gap-2 mb-1">
                        <span className="text-[9px] font-bold bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded uppercase">{task.subject}</span>
                        {isWarning && !isDateCompleted && (
                          <span className="text-[9px] font-bold text-red-500 flex items-center gap-0.5"><Flame size={10}/>残り{daysLeft}日</span>
                        )}
                      </div>
                      <p className={`font-bold text-sm truncate ${isDateCompleted ? 'text-slate-500 line-through' : 'text-slate-800'}`}>
                        {task.name}
                      </p>
                      <p className="text-xs text-slate-500 font-medium flex items-center gap-1 mt-1">
                        <Clock size={12}/> {task.dailyTime}分
                      </p>
                    </div>

                    {/* アクションボタン群 */}
                    <div className="flex items-center gap-1 shrink-0">
                      {!isDateCompleted && (
                        <button 
                          onClick={() => handleStartTask(task)}
                          className="w-10 h-10 bg-emerald-100 text-emerald-700 rounded-full flex items-center justify-center hover:bg-emerald-200 transition-colors mr-1"
                        >
                          <Play size={16} className="ml-0.5" />
                        </button>
                      )}
                      
                      {/* 順番入れ替えボタン */}
                      <div className="flex flex-col gap-1 border-l border-slate-100 pl-2">
                        <button 
                          onClick={() => moveTask(index, -1)} 
                          disabled={index === 0}
                          className="p-1 text-slate-400 hover:text-slate-700 disabled:opacity-30 disabled:hover:text-slate-400 bg-slate-50 rounded"
                        >
                          <ArrowUp size={14}/>
                        </button>
                        <button 
                          onClick={() => moveTask(index, 1)} 
                          disabled={index === displayTasks.length - 1}
                          className="p-1 text-slate-400 hover:text-slate-700 disabled:opacity-30 disabled:hover:text-slate-400 bg-slate-50 rounded"
                        >
                          <ArrowDown size={14}/>
                        </button>
                      </div>
                    </div>

                  </div>
                )
              })}
            </div>
          )}
          <div className="h-8"></div>
        </div>
      </div>
    );
  };

  const renderSchedule = () => {
    const today = new Date();
    const target = new Date(examDate);
    const diffDays = Math.ceil((target - today) / (1000 * 60 * 60 * 24));
    
    const months = [];
    let d = new Date(today.getFullYear(), today.getMonth(), 1);
    const end = new Date(target.getFullYear(), target.getMonth(), 1);
    const minEnd = new Date(today.getFullYear(), today.getMonth() + 2, 1);
    const finalEnd = end > minEnd ? end : minEnd;

    while (d <= finalEnd) {
      months.push(`${d.getFullYear()}/${(d.getMonth() + 1).toString().padStart(2, '0')}`);
      d.setMonth(d.getMonth() + 1);
    }

    const getColPos = (dateStr) => {
      const date = new Date(dateStr);
      const monthStr = `${date.getFullYear()}/${(date.getMonth() + 1).toString().padStart(2, '0')}`;
      const idx = months.indexOf(monthStr);
      if (idx === -1) {
        if (date < new Date(months[0])) return 2; 
        return months.length + 2; 
      }
      return idx + 2;
    };

    return (
      <div className="flex flex-col h-full bg-slate-100">
        <div className="bg-slate-900 text-white p-6 pt-10 pb-6 shadow-md shrink-0">
          <div className="flex items-center gap-3 mb-4">
            <button onClick={() => setCurrentScreen('dashboard')} className="p-2 bg-slate-800 hover:bg-slate-700 rounded-full transition-colors">
              <ArrowLeft size={18} />
            </button>
            <h2 className="text-lg font-bold">学習ロードマップ</h2>
          </div>
          
          <div className="bg-red-500/10 border border-red-500/30 rounded-xl p-4 text-center">
            <p className="text-red-200 text-xs mb-1 font-bold tracking-widest uppercase flex items-center justify-center gap-1">
              <AlertTriangle size={14} /> Time limit
            </p>
            <div className="text-3xl font-bold text-red-500 tracking-tighter">
              {diffDays > 0 ? `残り ${diffDays} 日` : 'TIME OVER'}
            </div>
            <p className="text-slate-400 text-xs mt-1">試験日: {examDate}</p>
          </div>
        </div>

        <div className="flex-1 overflow-y-auto p-4 space-y-4">
          <p className="text-xs font-bold text-slate-500 text-center">期間を確認して計画的に進めましょう</p>
          
          <div className="overflow-x-auto pb-4">
            <div className="min-w-[600px] bg-white border border-slate-200 rounded-2xl p-4 shadow-sm">
              <div style={{ display: 'grid', gridTemplateColumns: `120px repeat(${months.length}, 1fr)`, gap: '4px' }} className="mb-3">
                <div className="text-xs font-bold text-slate-400 border-b border-slate-200 pb-2">タスク名</div>
                {months.map((m, i) => {
                  const isCurrentMonth = i === 0;
                  return (
                    <div key={i} className={`text-[10px] text-center font-bold pb-2 border-b border-slate-200 ${isCurrentMonth ? 'text-red-500' : 'text-slate-500'}`}>
                      {m}
                      {isCurrentMonth && <div className="text-[8px] bg-red-100 text-red-600 rounded px-1 mt-0.5 inline-block">現在</div>}
                    </div>
                  );
                })}
              </div>

              <div className="space-y-3">
                {tasks.map((task) => {
                  const colStart = getColPos(task.startDate);
                  const colEnd = getColPos(task.deadline) + 1; 
                  
                  const daysLeft = Math.ceil((new Date(task.deadline) - new Date()) / (1000 * 60 * 60 * 24));
                  let barColor = "bg-emerald-500 text-white"; 
                  if (daysLeft <= 0) barColor = "bg-slate-800 text-red-400 border border-red-500"; 
                  else if (daysLeft <= 14) barColor = "bg-red-500 text-white shadow-red-200 shadow-md"; 
                  else if (daysLeft <= 30) barColor = "bg-orange-400 text-white"; 
                  
                  const isOver = daysLeft <= 0;

                  return (
                    <div key={task.id} style={{ display: 'grid', gridTemplateColumns: `120px repeat(${months.length}, 1fr)`, gap: '4px' }} className="items-center h-8 relative group">
                      <div className="absolute inset-0 pointer-events-none" style={{ display: 'grid', gridTemplateColumns: `120px repeat(${months.length}, 1fr)`, gap: '4px' }}>
                         <div></div>
                         {months.map((_, i) => <div key={i} className="border-l border-slate-100/50 h-full"></div>)}
                      </div>

                      <div className="text-[11px] font-bold text-slate-700 truncate pr-2 z-10">
                        <span className="text-[9px] text-slate-400 block -mb-1">{task.subject}</span>
                        {task.name}
                      </div>
                      
                      {colStart <= months.length + 1 && (
                        <div 
                          className={`rounded-md text-[10px] px-2 py-1 font-bold whitespace-nowrap overflow-hidden text-ellipsis flex items-center justify-between z-10 transition-all ${barColor}`} 
                          style={{ gridColumn: `${colStart} / ${colEnd}` }}
                        >
                          <span className="truncate">{task.dailyTime}分/日</span>
                          {!isOver && daysLeft > 0 && daysLeft <= 30 && <Flame size={12} className={daysLeft <= 14 ? "text-yellow-300" : "text-white"}/>}
                        </div>
                      )}
                    </div>
                  )
                })}
              </div>
            </div>
          </div>
        </div>
      </div>
    );
  };

  const renderTimer = () => {
    const formatTime = (seconds) => {
      const m = Math.floor(seconds / 60);
      const s = seconds % 60;
      return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    };

    const progress = timerTotal === 0 ? 0 : 1 - (timeLeft / timerTotal);

    return (
      <div className="flex flex-col h-full bg-slate-900 text-white relative overflow-hidden">
        <div className="absolute inset-0 bg-emerald-950/20 pointer-events-none"></div>
        
        <div className="flex-1 flex flex-col items-center justify-center p-8 z-10 space-y-12">
          <div className="text-center space-y-2">
            <h2 className="text-emerald-400 font-medium tracking-widest text-sm uppercase">Focus Mode</h2>
            <p className="text-2xl font-bold px-4">{activeTask?.name}</p>
            <p className="text-slate-400 text-sm">本日の目標: {activeTask?.dailyTime}分</p>
          </div>

          <div className="relative w-64 h-64 flex items-center justify-center">
            <svg className="absolute inset-0 w-full h-full -rotate-90">
              <circle cx="128" cy="128" r="120" className="stroke-slate-800 fill-none" strokeWidth="8" />
              <circle 
                cx="128" cy="128" r="120" 
                className={`fill-none transition-all duration-1000 ease-linear ${isDead ? 'stroke-red-500/50' : 'stroke-emerald-500'}`} 
                strokeWidth="8" strokeDasharray={2 * Math.PI * 120} strokeDashoffset={2 * Math.PI * 120 * (1 - progress)}
              />
            </svg>
            <div className="absolute inset-0 flex items-center justify-center -mt-4">
              <TreeGraphic progress={progress} isDead={isDead} />
            </div>
          </div>

          <div className="text-7xl font-light tabular-nums tracking-tight">
            {formatTime(timeLeft)}
          </div>

          {isDead && (
            <div className="text-red-400 font-bold animate-pulse text-center bg-red-900/30 p-4 rounded-xl">
              集中が途切れました。<br/>木が枯れてしまいました...
            </div>
          )}
        </div>

        <div className="p-8 pb-12 z-10">
          <button 
            onClick={handleGiveUp}
            disabled={isDead}
            className={`w-full py-4 rounded-2xl font-bold text-lg flex items-center justify-center gap-2 transition-all
              ${isDead ? 'bg-slate-800 text-slate-500 cursor-not-allowed' : 'bg-slate-800 hover:bg-slate-700 text-slate-300'}`}
          >
            あきらめる
          </button>
          {!isDead && (
             <button onClick={() => setTimeLeft(0)} className="w-full text-center text-xs text-slate-600 mt-6 underline">
               [Debug: タイマーを完了させる]
             </button>
          )}
        </div>
      </div>
    );
  };

  const renderReview = () => (
    <div className="flex flex-col h-full bg-emerald-50 p-6 overflow-y-auto">
      <div className="flex-1 flex flex-col items-center justify-start space-y-6 mt-6 max-w-sm mx-auto w-full">
        
        <div className="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-500 animate-bounce shrink-0">
          <Trophy size={40} />
        </div>
        
        <div className="text-center space-y-1">
          <h2 className="text-2xl font-bold text-slate-800">お疲れ様！</h2>
          <p className="text-slate-600 text-sm">時間が経過しました。振り返りをしましょう。</p>
        </div>

        <div className="w-full bg-white p-5 rounded-2xl shadow-sm border border-emerald-100 space-y-4">
          <div>
            <p className="text-xs font-bold text-emerald-600 uppercase tracking-wider mb-1">対象タスク</p>
            <p className="font-medium text-slate-800">{activeTask?.name}</p>
          </div>
          
          <div className="pt-2 border-t border-slate-100">
            <p className="text-sm font-bold text-slate-700 mb-3">この日の分は予定通りできましたか？</p>
            <div className="grid grid-cols-2 gap-3">
              <button 
                onClick={() => setTaskResult('success')}
                className={`flex flex-col items-center justify-center gap-2 py-3 rounded-xl border-2 transition-all ${
                  taskResult === 'success' ? 'border-emerald-500 bg-emerald-50 text-emerald-700' : 'border-slate-200 bg-white text-slate-500 hover:border-emerald-200'
                }`}
              >
                <ThumbsUp size={24} />
                <span className="font-bold text-sm">できた！</span>
              </button>
              <button 
                onClick={() => setTaskResult('fail')}
                className={`flex flex-col items-center justify-center gap-2 py-3 rounded-xl border-2 transition-all ${
                  taskResult === 'fail' ? 'border-orange-500 bg-orange-50 text-orange-700' : 'border-slate-200 bg-white text-slate-500 hover:border-orange-200'
                }`}
              >
                <AlertCircle size={24} />
                <span className="font-bold text-sm">もう少し...</span>
              </button>
            </div>

            {taskResult === 'fail' && (
              <div className="mt-4 p-4 bg-orange-50 rounded-xl border border-orange-100 animate-fade-in">
                <p className="text-sm font-bold text-orange-800 mb-2 flex items-center gap-2">
                  <CalendarClock size={16} />未完了分をいつやりますか？
                </p>
                <input 
                  type="date" value={rescheduleDate} onChange={(e) => setRescheduleDate(e.target.value)}
                  className="w-full p-2.5 rounded-lg border border-orange-200 text-slate-700 text-sm focus:ring-2 focus:ring-orange-500 bg-white"
                />
              </div>
            )}
          </div>
        </div>
      </div>

      <div className="pb-8 pt-4 shrink-0 mt-4">
        <button 
          onClick={handleSaveReview}
          className={`w-full py-4 rounded-2xl font-bold text-lg shadow-lg flex items-center justify-center gap-2 transition-all active:scale-95 ${
            taskResult ? 'bg-emerald-600 hover:bg-emerald-700 text-white shadow-emerald-200' : 'bg-slate-300 text-slate-500 cursor-not-allowed'
          }`}
        >
          記録を保存して戻る
          <ChevronRight size={20} />
        </button>
      </div>
    </div>
  );

  return (
    <div className="min-h-screen bg-slate-200 flex items-center justify-center p-4">
      <div className="w-full max-w-[400px] h-[850px] max-h-[90vh] bg-white rounded-[3rem] shadow-2xl overflow-hidden relative ring-8 ring-slate-800">
        <div className="absolute top-0 inset-x-0 h-7 flex justify-center z-50 pointer-events-none">
          <div className="w-32 h-6 bg-slate-800 rounded-b-3xl"></div>
        </div>
        {currentScreen === 'setup' && renderSetup()}
        {currentScreen === 'dashboard' && renderDashboard()}
        {currentScreen === 'schedule' && renderSchedule()}
        {currentScreen === 'timer' && renderTimer()}
        {currentScreen === 'review' && renderReview()}
      </div>
    </div>
  );
}